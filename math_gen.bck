import os
import json
import re
import webbrowser
from openai import OpenAI
from dotenv import load_dotenv

# 1. Load Environment Variables
load_dotenv()
KIMI_API_KEY = os.getenv("KIMI_API_KEY", "").strip()

# 2. Initialize the Client
client = OpenAI(
    api_key=KIMI_API_KEY,
    base_url="https://api.moonshot.ai/v1",
)

# Add this helper method to your script to generate random star coordinates
import random

def gen_stars(count):
    """Generates a string of random coordinates for CSS box-shadow stars."""
    stars = []
    for _ in range(count):
        # We use a large range (3000px) to ensure stars cover the whole scrollable area
        stars.append(f"{random.randint(0, 3000)}px {random.randint(0, 3000)}px #FFF")
    return ", ".join(stars)

def generate_html(data):
    """Wraps JSON data in a styled HTML template with an animated star field."""
    cards_html = ""
    for i, entry in enumerate(data, 1):
        cards_html += f"""
        <div class="relative bg-gray-800/80 backdrop-blur-md border border-indigo-500 p-6 rounded-xl shadow-lg mb-6 transform hover:scale-[1.01] transition-all z-10">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-indigo-400 font-bold uppercase tracking-tighter text-sm">Mission Log #{i}</h2>
                <span class="text-gray-500 text-[10px] font-mono uppercase tracking-widest">Sector: Fractions</span>
            </div>
            <p class="text-gray-100 text-lg leading-relaxed mb-8">{entry['question']}</p>
            <details class="group border-t border-gray-700 pt-4">
                <summary class="list-none cursor-pointer flex items-center gap-2 text-indigo-300 hover:text-indigo-200 transition-colors">
                    <span class="text-xs font-bold uppercase tracking-widest bg-indigo-900/50 px-3 py-1 rounded-full border border-indigo-500/30">
                        🛰️ Access Data Node
                    </span>
                    <span class="text-[10px] text-gray-500 group-open:hidden">(Click to Reveal Answer)</span>
                </summary>
                <div class="mt-4 bg-black/60 p-4 rounded-lg border border-dashed border-green-500/30">
                    <p class="text-green-400 font-mono text-sm">
                        <span class="text-gray-500 font-sans italic text-xs">CORRECT COORDINATES:</span><br>
                        <span class="text-lg font-bold">{entry['answer']}</span>
                    </p>
                </div>
            </details>
        </div>
        """
    
    # Notice we removed 'self.' below and call the function directly
    return f"""
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Space Fraction Quest</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <style>
            .stars-container {{
                position: fixed; top: 0; left: 0; width: 100%; height: 100%;
                background: radial-gradient(ellipse at bottom, #1B2735 0%, #090A0F 100%);
                overflow: hidden; z-index: 0;
            }}
            .star {{
                position: absolute; background: white; border-radius: 50%; opacity: 0.5;
                animation: move-stars linear infinite;
            }}
            .star-sm {{ width: 1px; height: 1px; animation-duration: 120s; }}
            .star-md {{ width: 2px; height: 2px; animation-duration: 80s; opacity: 0.7; }}
            .star-lg {{ width: 3px; height: 3px; animation-duration: 40s; opacity: 0.9; }}

            @keyframes move-stars {{
                from {{ transform: translateY(0); }}
                to {{ transform: translateY(-2000px); }}
            }}
            details summary::-webkit-details-marker {{ display:none; }}
        </style>
    </head>
    <body class="min-h-screen py-12 px-4 font-sans text-gray-100">
        
        <div class="stars-container">
            <div class="star star-sm" style="box-shadow: {gen_stars(400)}"></div>
            <div class="star star-md" style="box-shadow: {gen_stars(150)}"></div>
            <div class="star star-lg" style="box-shadow: {gen_stars(50)}"></div>
        </div>

        <div class="relative max-w-3xl mx-auto z-10">
            <header class="text-center mb-12">
                <h1 class="text-5xl font-black text-white tracking-tighter mb-2 italic drop-shadow-[0_5px_15px_rgba(99,102,241,0.5)]">SPACE QUEST</h1>
                <p class="text-indigo-300 uppercase tracking-widest text-xs font-semibold">Grade 5 Fraction Assessment Node</p>
            </header>
            <div id="quest-container">{cards_html}</div>
            <footer class="mt-12 text-center text-gray-500 text-[10px] tracking-widest uppercase">
                Systems Nominal // Math Engine v2.4 // Parallax Enabled
            </footer>
        </div>
    </body>
    </html>
    """

def generate_math_quest():
    if not KIMI_API_KEY:
        print("❌ Error: KIMI_API_KEY not found in .env file.")
        return

    print(f"🚀 Connecting to Kimi v2 (.ai)...")
    
    prompt_text = "Generate 5 math word problems for a 5th grader. Topic: Fractions. Theme: Space exploration. Format: Return ONLY a JSON list of objects with 'question' and 'answer' keys."

    try:
        # UPDATED: Model name changed to v2 and dictionary is safely handled
        response = client.chat.completions.create(
            model="moonshot-v1-8k",
            messages=[
                {"role": "system", "content": "You are a helpful assistant that strictly outputs JSON content."},
                {"role": "user", "content": prompt_text}
            ],
            temperature=0.3,
        )
        
        raw_content = response.choices[0].message.content
        match = re.search(r'\[.*\]', raw_content, re.DOTALL)
        if not match:
            print(f"❌ Error: Could not find JSON block in response.")
            return
            
        data = json.loads(match.group())
        os.makedirs("output", exist_ok=True)
        
        # Write HTML and Solution files
        html_path = "output/index.html"
        with open(html_path, "w") as f:
            f.write(generate_html(data))
        
        with open("output/solution.txt", "w") as s_file:
            s_file.write("--- SOLUTION KEY ---\n\n")
            for i, entry in enumerate(data, 1):
                s_file.write(f"Problem {i} Answer: {entry['answer']}\n\n")
        
        print(f"✅ Success! Opening {html_path} in browser...")
        webbrowser.open('file://' + os.path.realpath(html_path))

    except Exception as e:
        print(f"❌ Error: {e}")

if __name__ == "__main__":
    generate_math_quest()
